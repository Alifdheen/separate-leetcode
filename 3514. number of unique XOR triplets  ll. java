class Solution {
    public int uniqueXorTriplets(int[] nums) {
        java.util.HashSet<Integer> set = new java.util.HashSet<>();
        int n = nums.length;

        for (int i = 0; i < n; i++) {
            for (int j = i; j < n; j++) {
                int xor = nums[i] ^ nums[j];
                for (int k = j; k < n; k++) {
                    set.add(xor ^ nums[k]);
                }
            }
        }

        return set.size();
    }
}
